# PoetryTube — Environment Variables
# Copy this file to .env.local for local dev (never commit .env.local)
# In Vercel: add these under Project Settings → Environment Variables

# Required: your OpenAI API key (used by /api/ai serverless function)
OPENAI_API_KEY=sk-...

