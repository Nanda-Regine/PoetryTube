# ─── Supabase ───────────────────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here   # NEVER expose on client

# ─── OpenAI ─────────────────────────────────────────────────────────────────
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# ─── App ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000    # Change to your production URL
NEXT_PUBLIC_SITE_NAME=PoetryTube

# ─── Vercel Analytics (auto-injected on Vercel — no action needed) ──────────
# VERCEL_ANALYTICS_ID is auto-set by Vercel
