# PoetryTube — Environment Variables
# Copy to .env.local for local dev (never commit .env.local)
# Add ALL of these to: Vercel Dashboard → Project → Settings → Environment Variables

# OpenAI — server-side only (used in app/api/ai/route.ts)
OPENAI_API_KEY=sk-...

# Supabase — NEXT_PUBLIC_ prefix = safe for browser (anon key only)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Supabase service role key — server-side ONLY, never expose to browser
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# PayFast — payment gateway (server-side only)
PAYFAST_MERCHANT_ID=
PAYFAST_MERCHANT_KEY=
PAYFAST_PASSPHRASE=
PAYFAST_SANDBOX=true
